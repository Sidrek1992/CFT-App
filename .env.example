# Firebase client config
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_GOOGLE_APP_ID=your-google-app-id

# Cloud Functions base URL
VITE_FUNCTIONS_BASE_URL=https://us-central1-your-project-id.cloudfunctions.net
VITE_TRACKING_BASE_URL=https://us-central1-your-project-id.cloudfunctions.net

# Backend secrets (set in Firebase Functions, not in this file)
# firebase functions:secrets:set GEMINI_API_KEY
# firebase functions:secrets:set TRACKING_HMAC_SECRET
